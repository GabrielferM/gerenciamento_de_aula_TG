// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  createdAt DateTime @default(now())
  turmas    Turma[]
}

model Turma {
  id               Int       @id @default(autoincrement())
  descricao        String    
  quantidade_aluno Int
  periodo          String    
  usuario_id       Int
  usuario          Usuario   @relation(fields: [usuario_id], references: [id])
  alunos           Aluno[]
  agendas          Agenda[]
  projetos         Projeto[]
}

model Materia {
  id        Int       @id @default(autoincrement())
  nome      String    
  descricao String?
  agendas   Agenda[]
  projetos  Projeto[]
}

model Aluno {
  id        Int      @id @default(autoincrement())
  nome      String
  ra        String?  @unique 
  turma_id  Int
  turma     Turma    @relation(fields: [turma_id], references: [id])
  equipes   Equipe[] @relation("AlunoNasEquipes")
  presencas Presenca[]
}

model Agenda {
  id         Int      @id @default(autoincrement())
  dia        DateTime
  conteudo   String   
  status     String   @default("PLANEJADO") // PLANEJADO, REALIZADO
  arquivo    String?
  turma_id   Int
  turma      Turma    @relation(fields: [turma_id], references: [id])
  materia_id Int
  materia    Materia  @relation(fields: [materia_id], references: [id])
  presencas  Presenca[]
}

// NOVA: Para controlar quem faltou ou veio em cada aula da Agenda
model Presenca {
  id        Int     @id @default(autoincrement())
  presente  Boolean @default(true)
  aluno_id  Int
  aluno     Aluno   @relation(fields: [aluno_id], references: [id])
  agenda_id Int
  agenda    Agenda  @relation(fields: [agenda_id], references: [id])
}

model Projeto {
  id               Int      @id @default(autoincrement())
  titulo           String
  descricao        String?
  prazo_entrega    DateTime?
  turma_id         Int
  turma            Turma    @relation(fields: [turma_id], references: [id])
  materia_id       Int
  materia          Materia  @relation(fields: [materia_id], references: [id])
  equipes          Equipe[]
  tasks            Task[] // Conexão com tarefas do projeto
}

model Equipe {
  id         Int      @id @default(autoincrement())
  nome_grupo String
  projeto_id Int
  projeto    Projeto  @relation(fields: [projeto_id], references: [id])
  alunos     Aluno[]  @relation("AlunoNasEquipes")
}

// NOVA: Para o Roadmap e acompanhamento de tarefas que você citou
model Task {
  id          Int       @id @default(autoincrement())
  titulo      String
  descricao   String?
  status      String    @default("PENDENTE") // PENDENTE, EM_ANDAMENTO, CONCLUIDO
  data_limite DateTime?
  projeto_id  Int
  projeto     Projeto   @relation(fields: [projeto_id], references: [id])
}